pipeline {
    agent any 

    stages {
        stage('Cleaning Workspace') {
            steps {
                cleanWs()
            }
        }
        stage('Checkout from Git') {
            steps {
                git branch: 'main', url: 'https://github.com/xxhjshamxx/e-commerce-web-application-project.git'
            }
        }
        stage("Docker Image Build") {
            steps {
                script {
                    dir('src/productcatalogservice') {
                        sh 'docker system prune -f'
                        sh 'docker container prune -f'
                        sh 'docker build -t productcatalogservice .'
                    }
                }
            }
        }
        stage("ECR Image Pushing") {
            steps {
                script {
                    sh '''
                    #Retrieve an authentication token and authenticate your Docker client to your registry. Use the AWS CLI:
                    aws ecr get-login-password --region us-east-1 | docker login --username AWS --password-stdin 649126925327.dkr.ecr.us-east-1.amazonaws.com

                    #After the build completes, tag your image so you can push the image to this repository:
                    docker tag productcatalogservice:latest 649126925327.dkr.ecr.us-east-1.amazonaws.com/productcatalogservice:${BUILD_NUMBER}

                    #Run the following command to push this image to your newly created AWS repository:
                    docker push 649126925327.dkr.ecr.us-east-1.amazonaws.com/productcatalogservice:${BUILD_NUMBER}
                    '''
                }
            }
        }
        stage('Update Deployment file') {
            environment {
                GIT_REPO_NAME = "e-commerce-web-application-project"
                GIT_EMAIL = "ag9418383@gmail.com"
                GIT_USER_NAME = "xxhjshamxx"
                IMAGE_NAME = "productcatalogservice"
                REPO_URL = "649126925327.dkr.ecr.us-east-1.amazonaws.com/productcatalogservice"
                YAML_FILE = "productcatalogservice.yaml"
            }
            steps {
                dir('kubernetes-files') {
                    withCredentials([string(credentialsId: 'my-git-pattoken', variable: 'git_token')]) {
                        sh '''
                            git config user.email "${GIT_EMAIL}"
                            git config user.name "${GIT_USER_NAME}"
                            BUILD_NUMBER=${BUILD_NUMBER}
                            echo $BUILD_NUMBER

                            # push this image to your git hub
                            sed -i "s#image:.*#image: ${REPO_URL}:$BUILD_NUMBER#g" ${YAML_FILE}
                            git add .
                            git commit -m "Update ${IMAGE_NAME} Image to version \${BUILD_NUMBER}"
                            git push https://${git_token}@github.com/${GIT_USER_NAME}/${GIT_REPO_NAME} HEAD:main
        
                        '''
                    }
                }
            }
        }
    }
}
/*
 * =============================================================================
 * Jenkins CI/CD Declarative Pipeline
 * =============================================================================
 * 📝 Project Name: e-commerce-web-application-project (Microservice: productcatalogservice)
 * 🚀 Description : This pipeline automates the CI/CD lifecycle for the 
 * 'productcatalogservice' microservice. It cleans the workspace,
 * pulls the latest main branch code, builds the Docker image, 
 * pushes it to Amazon ECR, and updates the Kubernetes YAML via GitOps.
 *
 * 🛠️ Pipeline Stages:
 * 1. Cleaning Workspace    : Removes old build artifacts from the workspace.
 * 2. Checkout from Git     : Clones the latest code from the 'main' branch.
 * 3. Docker Image Build    : Prunes local docker cache and builds a fresh image.
 * 4. ECR Image Pushing     : Log into AWS ECR and pushes the new build-versioned image.
 * 5. Update Deployment file: Automatically updates the Kubernetes YAML image tag 
 * and pushes the update back to GitHub.
 * =============================================================================
 */
